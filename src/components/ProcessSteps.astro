---
interface Step {
  title: string;
  text: string;
}

interface Props {
  steps: Step[];
}

const { steps } = Astro.props;
---

<ol class="process-steps">
  {
    steps.map((step, index) => (
      <li data-reveal>
        <span class="step-number" aria-hidden="true">
          {String(index + 1).padStart(2, "0")}
        </span>
        <div>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </div>
      </li>
    ))
  }
</ol>
